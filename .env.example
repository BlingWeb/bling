# Copy this file to `.env` and fill in your Browserling credentials.
# `.env` is git-ignored — never commit real credentials.
#
# Optional. These only pre-fill the sign-in form when you run `bling login`;
# you still solve the reCAPTCHA yourself, so there is no unattended login.
# After the first login the driver reuses the session cookie from its persistent
# Chrome profile and never reads these again. If you'd rather type your
# credentials into the login window by hand, skip this file.
#
# Security note: this stores your password in plaintext on disk. Restrict file
# permissions, and prefer the persistent-cookie path. If Browserling ever offers a
# scoped API token, use that instead of a password.

BROWSERLING_EMAIL=you@example.com
BROWSERLING_PASSWORD=your-password-here

# Copy this file to `.env` and fill in your Browserling credentials.
# `.env` is git-ignored — never commit real credentials.
#
# Auth is "log in only if needed": the driver keeps a persistent Chrome profile,
# so after the first login the session cookie is reused and these are not touched.
# They're only used to auto-log-in when no valid cookie exists (e.g. unattended runs).
#
# Security note: this stores your password in plaintext on disk. Restrict file
# permissions, and prefer the persistent-cookie path. If Browserling ever offers a
# scoped API token, use that instead of a password.

BROWSERLING_EMAIL=you@example.com
BROWSERLING_PASSWORD=your-password-here
